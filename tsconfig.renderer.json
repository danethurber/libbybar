{
  // The strip renderer compiles separately: it must emit a plain browser
  // script (no CommonJS machinery). DOM types, no Node types.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "rootDir": "src/renderer",
    "outDir": "dist/renderer"
  },
  "include": ["src/renderer"]
}
